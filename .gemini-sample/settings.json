{
  "tools": {
    "enableHooks": true
  },
  "hooks": {
    "disabled": [],
    "enabled": true,
    "notifications": true,
    "BeforeAgent": [
      {
        "hooks": [
          {
            "name": "dnd-rag-context",
            "type": "command",
            "command": "uv --directory C:\\Development\\src\\_AI\\rag_dnd run rag-query-hook.py",
            "timeout": 30000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "dnd-rag-logger",
            "type": "command",
            "command": "uv --directory C:\\Development\\src\\_AI\\rag_dnd run rag-log-hook.py",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "rag-mcp": {
      "command": "uv",
      "args": [
        "--directory",
        "C:\\Development\\src\\_AI\\rag_dnd",
        "run",
        "rag-mcp-server.py"
      ]
    }
  }
}
